{
  "manifest_version": 3,
  "name": "Chrome Extension Receiver",
  "version": "1.0.0",
  "description": "Captures HTTP traffic via CDP and forwards to a local Python API",
  "permissions": [
    "debugger",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
